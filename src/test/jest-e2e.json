{
  "moduleFileExtensions": ["js", "json", "ts"],
  "modulePaths": ["<rootDir>"],
  "moduleNameMapper": {
    "@/(.*)$": "<rootDir>/$1"
  },
  "rootDir": "../",
  "testMatch": ["<rootDir>/test/index.e2e.spec.ts"],
  "preset": "ts-jest/presets/default-esm",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "useESM": true
      }
    ]
  },
  "extensionsToTreatAsEsm": [".ts"],
  "testEnvironment": "node",
  "testTimeout": 120000,
  "maxWorkers": 1
}

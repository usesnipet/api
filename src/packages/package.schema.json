{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://snipet.ai/schemas/package.schema.json",
  "title": "Snipet package manifest",
  "description": "Shape of package JSON files validated by packageManifestSchema (nodeTypes, configs, nodes).",
  "type": "object",
  "required": ["id", "name", "description", "version", "nodeTypes", "configs", "nodes"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor validation (optional)."
    },
    "id": {
      "type": "string",
      "description": "Stable package identifier."
    },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "version": {
      "type": "string",
      "description": "Semantic version of the package manifest.",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "docs": { "type": "string", "description": "Documentation URL." },
    "icon": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "author": { "type": "string" },
    "nodeTypes": {
      "type": "array",
      "items": { "$ref": "#/$defs/nodeType" }
    },
    "configs": {
      "type": "array",
      "items": { "$ref": "#/$defs/config" }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    }
  },
  "$defs": {
    "field": {
      "type": "object",
      "description": "Config field definition (fieldManifestSchema).",
      "required": ["name", "type", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^[a-zA-Z]+$"
        },
        "type": {
          "type": "string",
          "enum": ["string", "int", "float", "boolean", "json"],
          "description": "FieldType: string | int | float | boolean | json."
        },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "defaultValue": true,
        "encrypted": { "type": "boolean" }
      }
    },
    "inputWidget": {
      "type": "object",
      "description": "Optional UI widget for a node type input port.",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["text", "number", "checkbox", "select", "date", "time", "file", "json"]
        },
        "options": {
          "type": "array",
          "description": "Options for select widgets.",
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "placeholder": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "nodeTypeInput": {
      "type": "object",
      "required": ["name", "type", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^[a-zA-Z]+$"
        },
        "type": {
          "type": "string",
          "description": "Logical port type used for connection compatibility."
        },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "defaultValue": true,
        "inputWidget": { "$ref": "#/$defs/inputWidget" }
      }
    },
    "nodeTypeOutput": {
      "type": "object",
      "required": ["name", "type", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^[a-zA-Z]+$"
        },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "defaultValue": true
      }
    },
    "nodeTypeComponent": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "pattern": "^[a-zA-Z0-9]+$"
        },
        "type": { "type": "string" },
        "required": { "type": "boolean" }
      }
    },
    "nodeType": {
      "type": "object",
      "required": ["id", "name", "description"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "docs": { "type": "string", "description": "Documentation URL." },
        "icon": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nodeTypeInput" }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/nodeTypeOutput" }
        },
        "components": {
          "type": "array",
          "items": { "$ref": "#/$defs/nodeTypeComponent" }
        }
      }
    },
    "config": {
      "type": "object",
      "required": ["id", "name", "description"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "docs": { "type": "string", "description": "Documentation URL." },
        "icon": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        }
      }
    },
    "node": {
      "type": "object",
      "required": ["id", "name", "description", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "docs": { "type": "string", "description": "Documentation URL." },
        "icon": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "type": {
          "type": "string",
          "description": "References a node type id."
        },
        "config": {
          "type": "string",
          "description": "References a config id when the node requires configuration."
        }
      }
    }
  }
}

          "inputId"
        ]
      },
      "FlowConnectionManifest": {
        "type": "object",
        "properties": {
          "source": {
            "$ref": "#/components/schemas/FlowConnectionOutManifest"
          },
          "target": {
            "$ref": "#/components/schemas/FlowConnectionInManifest"
          },
          "active": {
            "type": "boolean"
          }
        },
        "required": [
          "source",
          "target",
          "active"
        ]
      },
      "FlowManifest": {
        "type": "object",
        "properties": {
          "nodes": {
            "default": [],
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FlowNodeRefManifest"
            }
          },
          "connections": {
            "default": [],
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FlowConnectionManifest"
            }
          }
        },
        "required": [
          "nodes",
          "connections"
        ]
      },
      "Flow": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          },
          "code": {
            "$ref": "#/components/schemas/FlowManifest"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "active",
          "code",
          "createdAt",
          "updatedAt"
        ]
      },

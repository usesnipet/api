          "instanceId": {
            "type": "string"
          },
          "nodeId": {
            "type": "string"
          },
          "config": {
            "type": "object",
            "additionalProperties": true
          },
          "vars": {
            "type": "object",
            "additionalProperties": true
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          }
        },
        "required": [
          "instanceId",
          "nodeId",
          "x",
          "y"
        ]
      },
      "FlowConnectionOutManifest": {
        "type": "object",
        "properties": {
          "instanceId": {
            "type": "string"
          },
          "outputId": {
            "type": "string"
          }
        },
        "required": [
          "instanceId",
          "outputId"
        ]
      },
      "FlowConnectionInManifest": {
        "type": "object",

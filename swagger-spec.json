  "components": {
    "securitySchemes": {
      "x-api-key": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API Key"
      }
    },
    "schemas": {
      "SystemInfo": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string"
          }
        },
        "required": [
          "version"
        ]
      },
      "Organization": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "slug": {
            "type": "string",
            "example": "acme-corp"
          },
          "name": {
            "type": "string",
            "example": "Acme Corp"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "slug",
          "name",
          "createdAt",
          "updatedAt"
        ]
      },
      "ApiErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Validation failed"
          },
          "error": {
            "type": "string",
            "example": "Bad Request"
          },
          "statusCode": {
            "type": "number",
            "example": 400
          }
        },
        "required": [
          "message",
          "error",
          "statusCode"
        ]
      },
      "CreateOrganizationDto": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "example": "acme-corp"
          },
          "name": {
            "type": "string",
            "example": "Acme Corp"
          }
        },
        "required": [
          "slug",
          "name"
        ]
      },
      "UpdateOrganizationDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Acme Corp"
          },
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      }
    }
  },
